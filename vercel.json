{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node",
      "config": { "includeFiles": ["index.js", "database.js"] }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "index.js"
    }
  ],
  "env": {
    "ALLOWED_ORIGINS": "https://sht-app.vercel.app,http://localhost:8081,exp://192.168.0.x"
  }
}
